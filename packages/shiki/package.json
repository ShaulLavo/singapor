{
  "name": "@editor/shiki",
  "private": true,
  "version": "0.1.0",
  "description": "Incremental, token-only parsing on top of Shiki.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "shiki": "^1.29.2"
  },
  "devDependencies": {
    "tsup": "^7.2.0",
    "typescript": "^5.9.3",
    "vitest": "^0.34.6"
  }
}

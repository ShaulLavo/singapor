{
  "name": "@editor/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "./src/style.css"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./editor": "./src/editor.ts",
    "./style.css": "./src/style.css"
  },
  "scripts": {
    "bench:anchors": "bun bench/pieceTable-anchors.ts",
    "bench:transforms": "bun bench/displayTransforms.ts",
    "bench:fold-map": "bun bench/foldMap.ts",
    "bench:piece-table": "bun bench/pieceTable-insertions.ts",
    "bench:syntax": "bun bench/treeSitter-syntax.ts",
    "bench:virtualization": "bun bench/virtualization.ts",
    "test": "vitest run",
    "test:browser": "vitest run --browser.enabled --browser.headless test/treeSitter-workerClient.browser.test.ts test/virtualizedTextView.browser.test.ts",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt ."
  },
  "dependencies": {
    "@tanstack/hotkeys": "0.8.0",
    "tree-sitter-css": "^0.25.0",
    "tree-sitter-html": "^0.23.2",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-json": "^0.24.8",
    "tree-sitter-typescript": "^0.23.2",
    "web-tree-sitter": "^0.26.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@typescript/native-preview": "latest",
    "@vitest/browser": "^3.2.4",
    "happy-dom": "^20.8.9",
    "oxfmt": "latest",
    "oxlint": "latest",
    "typescript": "~5.9.3",
    "vitest": "^3.1.1"
  }
}

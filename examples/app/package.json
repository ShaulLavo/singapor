{
  "name": "@editor/example-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsgo && vite build",
    "test": "vitest run --browser.enabled --browser.headless",
    "test:e2e": "playwright test",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@editor/core": "workspace:*",
    "@editor/find": "workspace:*",
    "@editor/gutters": "workspace:*",
    "@editor/minimap": "workspace:*",
    "@editor/shiki": "workspace:*",
    "@editor/tree-sitter-languages": "workspace:*",
    "@editor/typescript-lsp": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@typescript/native-preview": "latest",
    "@vitest/browser": "^3.2.4",
    "oxfmt": "latest",
    "oxlint": "latest",
    "typescript": "~5.9.3",
    "vite": "5.4.21",
    "vitest": "^3.1.1"
  }
}
